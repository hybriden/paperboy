# Paperboy environment (copy to .env for local dev; compose injects its own)
NODE_ENV=development

# Database
DATABASE_URL=postgresql://paperboy:paperboy@localhost:5433/paperboy

# API
API_PORT=8091
SESSION_SECRET=dev-session-secret-change-me-min-32-chars-long
CSRF_SECRET=dev-csrf-secret-change-me-min-32-chars-long
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:8090

# Admin SPA
VITE_API_URL=http://localhost:8091

# Web (Next.js reference frontend)
PAPERBOY_API_URL=http://localhost:8091
PAPERBOY_PUBLIC_KEY=pk_live_seed_public_key_value
PAPERBOY_PREVIEW_KEY=prv_seed_preview_key_value
PREVIEW_SECRET=dev-preview-secret-change-me
WEB_PORT=8092

# Seed admin user (created by db:seed)
SEED_ADMIN_EMAIL=admin@paperboy.test
SEED_ADMIN_PASSWORD=Admin!Passw0rd
