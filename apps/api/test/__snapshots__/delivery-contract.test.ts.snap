exports[`Delivery API — golden-shape contract freeze > GET /delivery/content?type=BlogPost (public) — frozen shape 1`] = `
{
  "cv": "<cv>",
  "items": [
    {
      "cv": "<cv>",
      "data": {
        "author": "Paperboy Team",
        "body": "## Why another CMS?

Because **content modelling should be data**, not code. Paperboy stores types in the database and serves them over a typed delivery API.

- Pages, blocks and globals
- Draft → preview → publish
- Multi-language with fallbacks",
        "publishDate": "<ts>",
        "summary": "Why we built another headless CMS — and what makes this one different.",
        "title": "Hello, Paperboy",
      },
      "documentId": "<id-1>",
      "kind": "page",
      "locale": "en",
      "name": "Hello, Paperboy",
      "seo": {
        "breadcrumb": [
          {
            "name": "Blog",
            "urlPath": "/blog",
          },
          {
            "name": "Hello, Paperboy",
            "urlPath": "/blog/hello-paperboy",
          },
        ],
        "canonicalPath": "/blog/hello-paperboy",
        "description": "Why we built another headless CMS — and what makes this one different.",
        "jsonLd": {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          "author": {
            "@type": "Person",
            "name": "Paperboy Team",
